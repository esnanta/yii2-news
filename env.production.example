# Production environment template
# Copy to .env on the hosting server and replace placeholder values.

# Framework
# ---------
YII_DEBUG=false
YII_ENV=prod
APP_MAINTENANCE=0

# Application
# -----------
LINK_ASSETS=false

# Databases
# ---------
DB_DSN=mysql:host=localhost;port=3306;dbname=your_production_db
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_TABLE_PREFIX=t_
DB_CHARSET=utf8mb4

# Optional test database (usually unused in production)
TEST_DB_DSN=mysql:host=localhost;port=3306;dbname=your_test_db
TEST_DB_USERNAME=your_test_db_user
TEST_DB_PASSWORD=your_test_db_password

# Urls (recommended: separate domains/subdomains)
# -----------------------------------------------
API_HOST_INFO=https://api.stiait.ac.id
FRONTEND_HOST_INFO=https://stiait.ac.id
BACKEND_HOST_INFO=https://backend.stiait.ac.id
STORAGE_HOST_INFO=https://storage.stiait.ac.id

# Keep base URLs empty when each app is served from domain root.
FRONTEND_BASE_URL=
BACKEND_BASE_URL=
STORAGE_BASE_URL=

# If your hosting forces one domain, use this instead:
# FRONTEND_BASE_URL=/
# BACKEND_BASE_URL=/backend
# STORAGE_BASE_URL=/storage

# Other
# -----
SMTP_HOST=your-smtp-host
SMTP_PORT=587

FRONTEND_COOKIE_VALIDATION_KEY=replace-with-long-random-string
BACKEND_COOKIE_VALIDATION_KEY=replace-with-long-random-string

ADMIN_EMAIL=admin@stiait.ac.id
ROBOT_EMAIL=robot@stiait.ac.id

GITHUB_CLIENT_ID=your-client-id
GITHUB_CLIENT_SECRET=your-client-secret

GLIDE_SIGN_KEY=replace-with-long-random-string
GLIDE_MAX_IMAGE_SIZE=4000000

