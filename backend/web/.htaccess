RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . index.php

# Redirect only direct legacy requests that still expose /backend/web.
RewriteCond %{THE_REQUEST} \s/+[^\s]*?/backend/web(?:/|\s|\?) [NC]
RewriteCond %{REQUEST_URI} ^/yii2-news/backend/web(?:/(.*))?$ [NC]
RewriteRule ^ /yii2-news/backend/%1 [R=301,L,NE]
